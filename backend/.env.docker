# Application
APP_ENV=production
DEBUG=false
HOST_PORT=8000

# Server
HOST=0.0.0.0
PORT=8000

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://expertie_user:expertie_password@postgres:5432/expertie_db

# PostgreSQL
POSTGRES_USER=expertie_user
POSTGRES_PASSWORD=expertie_password
POSTGRES_DB=expertie_db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# JWT Settings
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# External APIs - Tencent Translation
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_REGION=ap-shanghai

# AI Model API (OpenAI compatible - DeepSeek)
AI_API_KEY=your-ai-api-key
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# Translation Settings
TRANSLATION_CACHE_TTL=86400
TRANSLATION_MAX_RETRIES=3
TRANSLATION_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads
